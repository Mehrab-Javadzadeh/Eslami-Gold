ADMIN_PASSWORD_HASH=

# کلید مخفی برای امضای JWT
JWT_SECRET=

DATABASE_URL="file:./dev.db"

# اطلاعات فضای ذخیره‌سازی ابری لیارا (برای عکس محصولات)
